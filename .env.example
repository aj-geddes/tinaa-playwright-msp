# TINAA MSP Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Full SQLAlchemy async connection string.
# Production: point at a managed PostgreSQL + TimescaleDB instance.
DATABASE_URL=postgresql+asyncpg://tinaa:tinaa@localhost:5432/tinaa

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# Used for caching, task queues, and pub/sub.
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# GitHub App (required for GitHub integration)
# ---------------------------------------------------------------------------
# Create a GitHub App at https://github.com/settings/apps
GITHUB_APP_ID=
# PEM-encoded private key — paste the full multi-line value or use a file ref
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# API Security
# ---------------------------------------------------------------------------
# Random secret used to sign API tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
TINAA_API_KEY=

# ---------------------------------------------------------------------------
# Runtime mode
# ---------------------------------------------------------------------------
# api  — start the FastAPI HTTP server (default, recommended for production)
# mcp  — start the FastMCP stdio server (used when invoked by Claude Code)
TINAA_MODE=api

# ---------------------------------------------------------------------------
# Application behaviour
# ---------------------------------------------------------------------------
# Set to "true" to enable verbose debug logging. Never enable in production.
TINAA_DEBUG=false

# Number of uvicorn worker processes (production only; ignored in reload mode)
UVICORN_WORKERS=2

# ---------------------------------------------------------------------------
# Optional: notification and alerting integrations
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=

# ---------------------------------------------------------------------------
# Optional: SMTP (for email reports)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ---------------------------------------------------------------------------
# Optional: observability backends
# ---------------------------------------------------------------------------
# Jaeger / OTLP endpoint for distributed tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# Service name injected into all traces and structured logs
OTEL_SERVICE_NAME=tinaa-msp
